#!/bin/bash -e
# Prune safe caches (uv/pip/npm/pixi/conda on TMP_SCRATCH_DIR; HF under ~/.cache on /arc).

[[ -f /etc/profile.d/astroai.sh ]] && source /etc/profile.d/astroai.sh
for _libdir in /opt/astroai/lib "$(dirname "${BASH_SOURCE[0]}")/lib" "$(dirname "${BASH_SOURCE[0]}")/../lib"; do
    if [[ -f "${_libdir}/astroai-load.sh" ]]; then
        # shellcheck disable=SC1091
        source "${_libdir}/astroai-load.sh"
        astroai_source_common "${BASH_SOURCE[0]}"
        break
    fi
done

PIP=0
UV=0
HF=0
PIXI=0
NPM=0
CONDA=0
ALL=0

usage() {
    cat <<'EOF' >&2
astroai-cache-prune — clear package download caches (scratch and /arc).
Usage: astroai-cache-prune --all-safe | (--pip | --uv | --npm | --pixi | --conda | --hf)...
  --help for details
EOF
    exit 1
}

help_full() {
    cat <<'EOF'
astroai-cache-prune — clear package download caches (scratch and /arc).

Removes package manager caches on TMP_SCRATCH_DIR and Hugging Face models
under ~/.cache (/arc). Run astroai-home-usage first to see what's using space.

Usage:
  astroai-cache-prune --all-safe
  astroai-cache-prune (--pip | --uv | --npm | --pixi | --conda | --hf)...

Options:
  --pip             Clear PIP_CACHE_DIR.
  --uv              Run uv cache prune.
  --npm             Clear NPM_CONFIG_CACHE.
  --pixi            Remove PIXI_CACHE_DIR package cache (keeps envs).
  --conda           Remove MAMBA_PKGS_DIRS / CONDA_PKGS_DIRS (keeps envs).
  --hf              Remove HF_HOME (models must be re-downloaded).
  --all-safe        Equivalent to --pip --uv --npm --pixi --conda.
                    Does NOT include --hf (model re-download is expensive).
  -h                Show short usage summary.
  --help            Show this detailed help.

Examples:
  astroai-cache-prune --all-safe            # safe caches only
  astroai-cache-prune --pip --uv            # just pip and uv
  astroai-cache-prune --hf                  # remove HuggingFace models

Notes:
  • --all-safe is pip+uv+npm+pixi+conda (all safe to clear).
  • --hf removes downloaded models — they will need to be re-downloaded.
  • Check usage first: astroai-home-usage
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --pip) PIP=1; shift ;;
        --uv) UV=1; shift ;;
        --hf) HF=1; shift ;;
        --pixi) PIXI=1; shift ;;
        --conda) CONDA=1; shift ;;
        --npm) NPM=1; shift ;;
        --all-safe) ALL=1; shift ;;
        -h) usage ;;
        --help) help_full ;;
        *) astroai_err "Unknown option: $1"; usage ;;
    esac
done

if [[ "${ALL}" -eq 1 ]]; then
    PIP=1; UV=1; NPM=1; PIXI=1; CONDA=1
fi

if [[ "${PIP}" -eq 0 && "${UV}" -eq 0 && "${HF}" -eq 0 && "${PIXI}" -eq 0 && "${NPM}" -eq 0 && "${CONDA}" -eq 0 ]]; then
    usage
fi

if [[ "${PIP}" -eq 1 && -d "${PIP_CACHE_DIR:-}" ]]; then
    astroai_info "Clearing ${PIP_CACHE_DIR}..."
    rm -rf "${PIP_CACHE_DIR:?}"/*
fi

if [[ "${UV}" -eq 1 ]] && command -v uv >/dev/null; then
    astroai_info "Pruning uv cache..."
    uv cache prune
fi

if [[ "${HF}" -eq 1 && -d "${HF_HOME:-}" ]]; then
    astroai_warn "Removing ${HF_HOME}..."
    rm -rf "${HF_HOME:?}"
fi

if [[ "${PIXI}" -eq 1 && -d "${PIXI_CACHE_DIR:-}" ]]; then
    astroai_info "Clearing pixi package cache ${PIXI_CACHE_DIR}..."
    rm -rf "${PIXI_CACHE_DIR:?}"/*
fi

if [[ "${CONDA}" -eq 1 && -d "${MAMBA_PKGS_DIRS:-}" ]]; then
    astroai_info "Clearing conda/mamba package cache ${MAMBA_PKGS_DIRS}..."
    rm -rf "${MAMBA_PKGS_DIRS:?}"/*
fi

if [[ "${NPM}" -eq 1 && -d "${NPM_CONFIG_CACHE:-}" ]]; then
    astroai_info "Clearing ${NPM_CONFIG_CACHE}..."
    rm -rf "${NPM_CONFIG_CACHE:?}"/*
fi

astroai_ok "Done. Check: astroai-home-usage"
