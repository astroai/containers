#!/bin/bash -e
# Save a pixi or uv project environment for later resume.
#
# Default: lightweight save (lockfiles + manifest only, a few KB on /arc).
#   Rebuild the env on resume with pixi install / uv sync on /scratch.
#
# Usage:
#   astroai-env-save [name]
#   astroai-env-save mylab --full
#   astroai-env-save mylab --to /arc/projects/group/env-saves/mylab

for _libdir in /opt/astroai/lib "$(dirname "${BASH_SOURCE[0]}")/lib" "$(dirname "${BASH_SOURCE[0]}")/../lib"; do
    if [[ -f "${_libdir}/astroai-load.sh" ]]; then
        # shellcheck disable=SC1091
        source "${_libdir}/astroai-load.sh"
        astroai_source_common "${BASH_SOURCE[0]}"
        break
    fi
done

[[ -f /etc/profile.d/astroai.sh ]] && source /etc/profile.d/astroai.sh

FULL=0
DEST_OVERRIDE=""
NAME=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --full) FULL=1; shift ;;
        --to)
            [[ -n "${2:-}" ]] || { echo "--to requires a path" >&2; exit 1; }
            DEST_OVERRIDE="$2"
            shift 2
            ;;
        -h|--help)
            sed -n '2,12p' "$0"
            exit 0
            ;;
        *)
            NAME="$1"
            shift
            ;;
    esac
done

KIND="$(astroai_require_project)"
NAME="${NAME:-$(basename "${PWD}")}"
STAMP="$(astroai_timestamp)"
astroai_ensure_save_root

if [[ -n "${DEST_OVERRIDE}" ]]; then
    SAVE_DIR="${DEST_OVERRIDE%/}"
else
    SAVE_DIR="$(astroai_save_root)/${NAME}"
fi

mkdir -p "${SAVE_DIR}"

case "${KIND}" in
    pixi)
        cp -a pixi.toml "${SAVE_DIR}/"
        [[ -f pixi.lock ]] && cp -a pixi.lock "${SAVE_DIR}/"
        ;;
    uv)
        cp -a pyproject.toml "${SAVE_DIR}/"
        [[ -f uv.lock ]] && cp -a uv.lock "${SAVE_DIR}/"
        ;;
esac

for f in .python-version README.md; do
    if [[ -f "${f}" ]]; then cp -a "${f}" "${SAVE_DIR}/"; fi
done

if [[ ! "${PWD}" =~ ^/scratch(/|$) && -d /scratch ]]; then
    astroai_warn "Note: saving from ${PWD} — prefer /scratch for active projects."
fi

if [[ "${FULL}" -eq 1 ]]; then
    case "${KIND}" in
        pixi) ENV_DIR=".pixi" ;;
        uv)   ENV_DIR=".venv" ;;
    esac

    [[ -d "${ENV_DIR}" ]] || { astroai_err "No ${ENV_DIR} directory to pack."; exit 1; }

    ENV_SIZE="$(du -sh "${ENV_DIR}" | awk '{print $1}')"
    astroai_info "Environment size: ${ENV_SIZE}"

    if command -v df >/dev/null 2>&1; then
        echo "Destination free space:"
        df -h "${SAVE_DIR}" 2>/dev/null | awk 'NR>1 {print $4, "available on", $6}'
    fi

    echo ""
    read -r -p "Pack ${ENV_SIZE} to ${SAVE_DIR}? [y/N] " CONFIRM || true
    if [[ "${CONFIRM}" != "y" && "${CONFIRM}" != "Y" ]]; then
        astroai_hint "Cancelled."
        exit 0
    fi

    astroai_info "Packing environment..."
    tar -C . -cf - "${ENV_DIR}" | zstd -T0 -o "${SAVE_DIR}/env.tar.zst"
fi

MANIFEST="${SAVE_DIR}/manifest.json"
jq -n \
    --arg name "${NAME}" \
    --arg kind "${KIND}" \
    --arg saved_at "${STAMP}" \
    --arg saved_from "${PWD}" \
    --arg user "${USER}" \
    --argjson full "${FULL}" \
    '{name: $name, kind: $kind, saved_at: $saved_at, saved_from: $saved_from, user: $user, full: $full}' \
    > "${MANIFEST}"

du -sh "${SAVE_DIR}"
astroai_ok "Saved ${KIND} environment '${NAME}' -> ${SAVE_DIR}"
astroai_cmd "Resume on /scratch: astroai-env-resume ${NAME}"
