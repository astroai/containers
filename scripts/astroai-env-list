#!/bin/bash -e
# List saved environment manifests.
#
# Usage:
#   astroai-env-list              personal saves only
#   astroai-env-list --team       team saves on /arc/projects
#   astroai-env-list --all        personal + team

for _libdir in /opt/astroai/lib "$(dirname "${BASH_SOURCE[0]}")/lib" "$(dirname "${BASH_SOURCE[0]}")/../lib"; do
    if [[ -f "${_libdir}/astroai-load.sh" ]]; then
        # shellcheck disable=SC1091
        source "${_libdir}/astroai-load.sh"
        astroai_source_common "${BASH_SOURCE[0]}"
        break
    fi
done

usage() {
    cat <<'EOF' >&2
astroai-env-list — list saved environment manifests.
Usage: astroai-env-list [--team] [--all]
  --help for details
EOF
    exit 1
}

help_full() {
    cat <<'EOF'
astroai-env-list — list saved environment manifests.

Shows environments previously saved with astroai-env-save, including
name, kind (pixi/uv), timestamp, full-pack status, size, and user.

Usage:
  astroai-env-list [--team] [--all]

Options:
  --team            Show team saves under /arc/projects/*/env-saves/.
  --all             Show both personal and team saves.
  -h                Show short usage summary.
  --help            Show this detailed help.

Examples:
  astroai-env-list              # personal saves only
  astroai-env-list --team       # team saves on /arc/projects
  astroai-env-list --all        # personal + team

Notes:
  • Personal saves are stored under the default save root.
  • Team saves can be created with:
      astroai-env-save mylab --to /arc/projects/<group>/env-saves/mylab
  • Resume any listed save with:
      astroai-env-resume <name>
EOF
    exit 0
}

TEAM=0
ALL=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --team) TEAM=1; shift ;;
        --all)  ALL=1; shift ;;
        -h) usage ;;
        --help) help_full ;;
        *) astroai_err "Unknown option: $1"; usage ;;
    esac
done

if [[ "${ALL}" -eq 1 ]]; then
    TEAM=1
fi

SHOW_PERSONAL=1
if [[ "${TEAM}" -eq 1 && "${ALL}" -eq 0 ]]; then
    SHOW_PERSONAL=0
fi

list_saves() {
    local root="$1"
    local label="$2"

    if [[ ! -d "${root}" ]]; then
        echo "${label}: (none)"
        return
    fi

    local found=0
    while read -r m; do
        found=1
        dir="$(dirname "${m}")"
        name="$(jq -r .name "${m}")"
        kind="$(jq -r .kind "${m}")"
        at="$(jq -r .saved_at "${m}")"
        full="$(jq -r .full "${m}")"
        user="$(jq -r .user "${m}")"
        sz="$(du -sh "${dir}" 2>/dev/null | awk '{print $1}')"
        printf "  %-16s %-5s %s  full=%-5s %6s  %s\n" "${name}" "${kind}" "${at}" "${full}" "${sz}" "${user}"
    done < <(find "${root}" -name manifest.json 2>/dev/null)

    if [[ "${found}" -eq 0 ]]; then
        echo "${label}: (none)"
    fi
}

# ── Personal saves ──────────────────────────────
if [[ "${SHOW_PERSONAL}" -eq 1 ]]; then
    ROOT="$(astroai_save_root)"
    astroai_heading "Personal saves: ${ROOT}"
    list_saves "${ROOT}" "  "
fi

# ── Team saves ───────────────────────────────────
if [[ "${TEAM}" -eq 1 ]]; then
    echo ""
    astroai_heading "Team saves (/arc/projects/<project>/env-saves/):"
    if [[ -d /arc/projects ]]; then
        team_found=0
        for proj in /arc/projects/*/; do
            [[ -d "${proj}" && -r "${proj}" ]] || continue
            saves_dir="${proj}env-saves"
            if [[ -d "${saves_dir}" ]]; then
                team_found=1
                proj_name="$(basename "${proj}")"
                echo "  [${proj_name}]"
                list_saves "${saves_dir}" "    "
                echo ""
            fi
        done
        if [[ "${team_found}" -eq 0 ]]; then
            echo "  (no team env-saves found)"
        fi
    else
        echo "  /arc/projects not mounted"
    fi
fi

if [[ "${SHOW_PERSONAL}" -eq 1 ]]; then
    echo ""
    astroai_hint "Tip: team saves can live under /arc/projects/<group>/env-saves/"
    astroai_cmd "     astroai-env-list --team"
    astroai_cmd "     astroai-env-resume <name> --from /arc/projects/<group>/env-saves/<name>"
fi
