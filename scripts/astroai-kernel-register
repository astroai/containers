#!/bin/bash -e
# Register a pixi/uv/venv project as a Jupyter kernel (on demand).
#
# Kernelspecs persist under ~/.local/share/jupyter/kernels on /arc.
# Re-run after astroai-env-resume when /scratch was wiped (paths change).
#
# Usage:
#   astroai-kernel-register                 current directory
#   astroai-kernel-register /scratch/mylab  project path
#   astroai-kernel-register --name mylab    override kernelspec name
#   astroai-kernel-register --list          show project-linked kernels
#   astroai-kernel-register --unregister    remove kernel for this project

[[ -f /etc/profile.d/astroai.sh ]] && source /etc/profile.d/astroai.sh
for _libdir in /opt/astroai/lib "$(dirname "${BASH_SOURCE[0]}")/lib" "$(dirname "${BASH_SOURCE[0]}")/../lib"; do
    if [[ -f "${_libdir}/astroai-load.sh" ]]; then
        # shellcheck disable=SC1091
        source "${_libdir}/astroai-load.sh"
        astroai_source_common "${BASH_SOURCE[0]}"
        break
    fi
done

# Notebook sessions set JUPYTER_CONFIG_DIR=/etc/jupyter (root-owned). User CLI
# subcommands (kernelspec list, ipykernel install) need a writable config dir.
export JUPYTER_CONFIG_DIR="${HOME}/.jupyter"
mkdir -p "${JUPYTER_CONFIG_DIR}"

PROJECT_ROOT=""
KERNEL_NAME=""
UNREGISTER=0
LIST=0

usage() {
    sed -n '2,12p' "$0"
    exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --name)
            [[ -n "${2:-}" ]] || { echo "--name requires a value" >&2; exit 1; }
            KERNEL_NAME="$2"
            shift 2
            ;;
        --unregister|-u)
            UNREGISTER=1
            shift
            ;;
        --list|-l)
            LIST=1
            shift
            ;;
        -h|--help)
            usage 0
            ;;
        -*)
            echo "Unknown option: $1" >&2
            usage 1
            ;;
        *)
            [[ -z "${PROJECT_ROOT}" ]] || { echo "Unexpected argument: $1" >&2; usage 1; }
            PROJECT_ROOT="$1"
            shift
            ;;
    esac
done

astroai_kernel_meta_dir() {
    echo "${1}/.astroai"
}

astroai_kernel_meta_file() {
    echo "$(astroai_kernel_meta_dir "$1")/kernel.json"
}

astroai_sanitize_kernel_name() {
    local raw="$1"
    echo "${raw}" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+|-+$//g; s/-+/-/g'
}

astroai_default_kernel_name() {
    local root="$1"
    local kind="$2"
    astroai_sanitize_kernel_name "$(basename "${root}")-${kind}"
}

astroai_resolve_project() {
    local start="${1:-${PWD}}"
    local dir="${start}"

    if [[ -f "${dir}/pixi.toml" || -f "${dir}/pyproject.toml" || -d "${dir}/.venv" ]]; then
        echo "${dir}"
        return 0
    fi

    while [[ "${dir}" != "/" ]]; do
        if [[ -f "${dir}/pixi.toml" || -f "${dir}/pyproject.toml" || -d "${dir}/.venv" ]]; then
            echo "${dir}"
            return 0
        fi
        dir="$(dirname "${dir}")"
    done

    return 1
}

astroai_project_kind() {
    local root="$1"

    if [[ -f "${root}/pixi.toml" ]]; then
        echo pixi
    elif [[ -f "${root}/pyproject.toml" && -f "${root}/uv.lock" ]]; then
        echo uv
    elif [[ -f "${root}/pyproject.toml" ]]; then
        echo uv
    elif [[ -d "${root}/.venv" ]]; then
        echo venv
    else
        echo ""
    fi
}

astroai_project_python() {
    local root="$1"
    local kind="$2"

    case "${kind}" in
        pixi)
            command -v pixi >/dev/null || { echo "pixi not found" >&2; return 1; }
            (cd "${root}" && pixi run python -c 'import sys; print(sys.executable)')
            ;;
        uv)
            if [[ -x "${root}/.venv/bin/python" ]]; then
                echo "${root}/.venv/bin/python"
                return 0
            fi
            command -v uv >/dev/null || { echo "uv not found" >&2; return 1; }
            (cd "${root}" && uv run python -c 'import sys; print(sys.executable)')
            ;;
        venv)
            [[ -x "${root}/.venv/bin/python" ]] || {
                echo "No .venv/bin/python under ${root}" >&2
                return 1
            }
            echo "${root}/.venv/bin/python"
            ;;
        *)
            echo "Unsupported project kind: ${kind}" >&2
            return 1
            ;;
    esac
}

astroai_ensure_ipykernel() {
    local root="$1"
    local kind="$2"
    local python="$3"

    if "${python}" -c 'import ipykernel' 2>/dev/null; then
        return 0
    fi

    echo "Adding ipykernel to ${kind} environment..."
    case "${kind}" in
        pixi)
            (cd "${root}" && pixi add ipykernel)
            ;;
        uv)
            (cd "${root}" && uv add ipykernel)
            ;;
        venv)
            "${python}" -m pip install -q ipykernel
            ;;
    esac
}

astroai_kernelspec_dir() {
    local name="$1"
    echo "${HOME}/.local/share/jupyter/kernels/${name}"
}

astroai_write_kernel_meta() {
    local root="$1"
    local name="$2"
    local kind="$3"
    local python="$4"
    local meta_dir
    meta_dir="$(astroai_kernel_meta_dir "${root}")"
    mkdir -p "${meta_dir}"
    jq -n \
        --arg name "${name}" \
        --arg kind "${kind}" \
        --arg python "${python}" \
        --arg root "${root}" \
        --arg at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '{kernelspec_name: $name, kind: $kind, python: $python, project_root: $root, registered_at: $at}' \
        > "$(astroai_kernel_meta_file "${root}")"
}

astroai_read_kernel_name() {
    local root="$1"
    local meta
    meta="$(astroai_kernel_meta_file "${root}")"
    if [[ -f "${meta}" ]]; then
        jq -r .kernelspec_name "${meta}"
        return 0
    fi
    astroai_default_kernel_name "${root}" "$(astroai_project_kind "${root}")"
}

astroai_remove_kernel() {
    local name="$1"
    rm -rf "$(astroai_kernelspec_dir "${name}")"
}

astroai_list_kernels() {
    local found=0
    local search_root meta name kind root at py status

    echo "AstroAI-linked Jupyter kernels:"
    for search_root in /scratch "${HOME}"; do
        [[ -d "${search_root}" ]] || continue
        while IFS= read -r meta; do
            found=1
            name="$(jq -r .kernelspec_name "${meta}")"
            kind="$(jq -r .kind "${meta}")"
            root="$(jq -r .project_root "${meta}")"
            at="$(jq -r .registered_at "${meta}")"
            py="$(jq -r .python "${meta}")"
            status="ok"
            [[ -x "${py}" ]] || status="missing env (re-run astroai-kernel-register)"
            printf "  %-20s %-4s %s\n    %s\n    registered %s\n" "${name}" "${kind}" "${root}" "${status}" "${at}"
        done < <(find "${search_root}" -path '*/.astroai/kernel.json' 2>/dev/null | sort -u)
    done

    if [[ "${found}" -eq 0 ]]; then
        echo "  (none found — run astroai-kernel-register in a project)"
    fi

    echo ""
    if command -v jupyter >/dev/null 2>&1; then
        echo "All kernelspecs:"
        jupyter kernelspec list
    else
        echo "jupyter not installed in this session (notebook image required to use kernels in Lab)."
    fi
}

if [[ "${LIST}" -eq 1 ]]; then
    astroai_list_kernels
    exit 0
fi

if [[ -z "${PROJECT_ROOT}" ]]; then
    PROJECT_ROOT="$(astroai_resolve_project "${PWD}")" || {
        echo "No pixi/uv/venv project found (need pixi.toml, pyproject.toml, or .venv)." >&2
        echo "Usage: astroai-kernel-register [path]" >&2
        exit 1
    }
else
    PROJECT_ROOT="$(cd "${PROJECT_ROOT}" && pwd)"
    PROJECT_ROOT="$(astroai_resolve_project "${PROJECT_ROOT}")" || {
        echo "Not a pixi/uv/venv project: ${PROJECT_ROOT}" >&2
        exit 1
    }
fi

KIND="$(astroai_project_kind "${PROJECT_ROOT}")"
[[ -n "${KIND}" ]] || { echo "Could not detect project kind in ${PROJECT_ROOT}" >&2; exit 1; }

if [[ -z "${KERNEL_NAME}" ]]; then
    KERNEL_NAME="$(astroai_read_kernel_name "${PROJECT_ROOT}")"
fi
KERNEL_NAME="$(astroai_sanitize_kernel_name "${KERNEL_NAME}")"
[[ -n "${KERNEL_NAME}" ]] || { echo "Invalid kernel name" >&2; exit 1; }

if [[ "${UNREGISTER}" -eq 1 ]]; then
    astroai_remove_kernel "${KERNEL_NAME}"
    rm -f "$(astroai_kernel_meta_file "${PROJECT_ROOT}")"
    echo "Removed kernelspec: ${KERNEL_NAME}"
    exit 0
fi

PYTHON="$(astroai_project_python "${PROJECT_ROOT}" "${KIND}")"
[[ -n "${PYTHON}" && -x "${PYTHON}" ]] || {
    echo "Python not found for ${KIND} project — run pixi install or uv sync first." >&2
    exit 1
}

astroai_ensure_ipykernel "${PROJECT_ROOT}" "${KIND}" "${PYTHON}"
PYTHON="$(astroai_project_python "${PROJECT_ROOT}" "${KIND}")"

DISPLAY_NAME="Python ($(basename "${PROJECT_ROOT}") · ${KIND})"
SPEC_DIR="$(astroai_kernelspec_dir "${KERNEL_NAME}")"

astroai_remove_kernel "${KERNEL_NAME}"
"${PYTHON}" -m ipykernel install --user --name="${KERNEL_NAME}" --display-name="${DISPLAY_NAME}"
astroai_write_kernel_meta "${PROJECT_ROOT}" "${KERNEL_NAME}" "${KIND}" "${PYTHON}"

echo ""
astroai_ok "Registered Jupyter kernel:"
astroai_kv "  name:" "${KERNEL_NAME}"
astroai_kv "  display:" "${DISPLAY_NAME}"
astroai_kv "  python:" "${PYTHON}"
echo ""
if [[ -n "${JUPYTER_TOKEN:-}" || "${JUPYTER_CONFIG_DIR:-}" == /etc/jupyter ]]; then
    astroai_cmd "Open JupyterLab → Kernel picker → \"${DISPLAY_NAME}\""
    astroai_hint "If the list looks stale, refresh the browser tab."
else
    astroai_hint "Notebook session: pick \"${DISPLAY_NAME}\" in the JupyterLab kernel menu."
    astroai_hint "Other sessions: kernel is saved for your next notebook launch."
fi
echo ""
astroai_hint "Re-run after astroai-env-resume when /scratch was wiped."
astroai_cmd "Remove: astroai-kernel-register --unregister"
