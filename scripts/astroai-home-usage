#!/bin/bash -e
# Show what is using space under $HOME on shared /arc (CephFS).

[[ -f /etc/profile.d/astroai.sh ]] && source /etc/profile.d/astroai.sh
source /opt/astroai/lib/astroai-env-common.sh

echo "Home disk usage for ${USER} (${HOME})"
echo "========================================"

# Quota overview
astroai_quota_line "${HOME}" "home"

# Project quotas
if [[ -d /arc/projects ]]; then
    for proj in /arc/projects/*/; do
        [[ -d "${proj}" && -r "${proj}" ]] && astroai_quota_line "${proj}" "$(basename "${proj}")"
    done
fi
echo ""

entries=(
    ".cache:tool caches (uv, pip, HF, torch, …)"
    ".pixi:pixi global envs and package cache"
    ".local:user tools and data"
    ".astroai:env save manifests"
    ".config:application config"
    ".ssh:SSH keys (keep small)"
)

total=0
for entry in "${entries[@]}"; do
    dir="${entry%%:*}"
    label="${entry#*:}"
    path="${HOME}/${dir}"
    if [[ -e "${path}" ]]; then
        bytes="$(du -sb "${path}" 2>/dev/null | awk '{print $1}')"
        human="$(du -sh "${path}" 2>/dev/null | awk '{print $1}')"
        printf "  %-10s %8s  %s\n" "${dir}" "${human}" "${label}"
        total=$((total + bytes))
    fi
done

echo ""
echo "Other top-level entries:"
du -sh "${HOME}"/* 2>/dev/null | grep -vE '/\.(cache|pixi|local|astroai|config|ssh)$' | head -10 || true

echo ""
total_h="$(numfmt --to=iec-i --suffix=B "${total}" 2>/dev/null || du -sh "${HOME}" | awk '{print $1}')"
echo "Tracked profile dirs: ~${total_h}"

# Show quota percentage summary
_pct="$(astroai_quota_used_pct "${HOME}")"
if [[ -n "${_pct}" ]]; then
    if [[ "${_pct}" -ge 95 ]]; then
        echo "Quota:  ${_pct}% used ⚠ CRITICAL — prune immediately"
    elif [[ "${_pct}" -ge 90 ]]; then
        echo "Quota:  ${_pct}% used ⚠ high — prune soon"
    elif [[ "${_pct}" -ge 80 ]]; then
        echo "Quota:  ${_pct}% used ⚠ monitor"
    else
        echo "Quota:  ${_pct}% used"
    fi
fi

echo ""
echo "Keep $HOME lean on shared storage:"
echo "  - code and active envs on /scratch"
echo "  - lockfile saves via astroai-env-save (not full packs unless needed)"
echo "  - prune caches: astroai-cache-prune --help"
