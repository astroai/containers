#!/bin/bash -e
# Show what is using space under $HOME on shared /arc (CephFS).

[[ -f /etc/profile.d/astroai.sh ]] && source /etc/profile.d/astroai.sh
for _libdir in /opt/astroai/lib "$(dirname "${BASH_SOURCE[0]}")/lib" "$(dirname "${BASH_SOURCE[0]}")/../lib"; do
    if [[ -f "${_libdir}/astroai-load.sh" ]]; then
        # shellcheck disable=SC1091
        source "${_libdir}/astroai-load.sh"
        astroai_source_common "${BASH_SOURCE[0]}"
        break
    fi
done

usage() {
    cat <<'EOF' >&2
astroai-home-usage — disk breakdown under $HOME on /arc.
Usage: astroai-home-usage
  --help for details
EOF
}

help_full() {
    cat <<'EOF'
astroai-home-usage — disk breakdown under $HOME on /arc.

Usage:
  astroai-home-usage

Options:
  -h          Short help (stderr, exit 1)
  --help      This help (stdout, exit 0)

Checks CephFS quota limits and prints a breakdown of the largest directories
under your persistent home directory (~/.cache, ~/.pixi, etc.) to help
identify what's taking up storage space on the shared CANFAR mount.

No arguments required.
EOF
}

case "${1:-}" in
    -h) usage; exit 1 ;;
    --help) help_full; exit 0 ;;
    "") ;;
    *)
        astroai_err "Unexpected argument: $1"
        usage
        exit 1
        ;;
esac

astroai_title "Home disk usage for ${USER} (${HOME})"
astroai_divider

astroai_quota_line "${HOME}" "home"

if [[ -d /arc/projects ]]; then
    for proj in /arc/projects/*/; do
        [[ -d "${proj}" && -r "${proj}" ]] && astroai_quota_line "${proj}" "$(basename "${proj}")"
    done
fi
echo ""

entries=(
    ".cache:ML/tool caches on /arc (HF, torch, matplotlib, …)"
    ".pixi:pixi global envs (package cache on /scratch when mounted)"
    ".local/share/micromamba:micromamba root prefix (pkgs cache on /scratch when mounted)"
    ".local:user tools and data"
    ".astroai:env save manifests"
    ".config:application config"
    ".ssh:SSH keys (keep small)"
)

total=0
for entry in "${entries[@]}"; do
    dir="${entry%%:*}"
    label="${entry#*:}"
    path="${HOME}/${dir}"
    if [[ -e "${path}" ]]; then
        bytes="$(du -sb "${path}" 2>/dev/null | awk '{print $1}')"
        human="$(du -sh "${path}" 2>/dev/null | awk '{print $1}')"
        if astroai_ui_enabled; then
            printf '  %b%-10s%b %8s  %s\n' $'\033[1m' "${dir}" $'\033[0m' "${human}" "${label}"
        else
            printf "  %-10s %8s  %s\n" "${dir}" "${human}" "${label}"
        fi
        total=$((total + bytes))
    fi
done

echo ""
astroai_heading "Other top-level entries:"
du -sh "${HOME}"/* 2>/dev/null | grep -vE '/\.(cache|pixi|local|astroai|config|ssh)$' | head -10 | sed 's/^/  /' || true

echo ""
total_h="$(numfmt --to=iec-i --suffix=B "${total}" 2>/dev/null || du -sh "${HOME}" | awk '{print $1}')"
astroai_kv "Tracked:" "~${total_h}"

_pct="$(astroai_quota_used_pct "${HOME}")"
if [[ -n "${_pct}" ]]; then
    if [[ "${_pct}" -ge 95 ]]; then
        astroai_err "Quota:  ${_pct}% used ⚠ CRITICAL — prune immediately"
    elif [[ "${_pct}" -ge 90 ]]; then
        astroai_warn "Quota:  ${_pct}% used ⚠ high — prune soon"
    elif [[ "${_pct}" -ge 80 ]]; then
        astroai_warn "Quota:  ${_pct}% used ⚠ monitor"
    else
        astroai_kv "Quota:" "${_pct}% used"
    fi
fi

echo ""
astroai_heading "Keep \$HOME lean on shared storage:"
astroai_hint "  - code and active envs on TMP_SRC_DIR (default /srcdir)"
astroai_hint "  - uv/pip/pixi/npm/conda download caches on TMP_SCRATCH_DIR (see astroai-status)"
astroai_hint "  - lockfile saves via astroai-env-save (not full packs unless needed)"
astroai_cmd "  - prune caches: astroai-cache-prune --help"
